{
  "dashboard": {
    "id": null,
    "title": "PostgreSQL DCA Overview",
    "tags": ["postgresql", "dca"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "pg_stat_activity_count",
            "legendFormat": "Total Connections"
          },
          {
            "expr": "pg_stat_activity_count{state=\"active\"}",
            "legendFormat": "Active"
          },
          {
            "expr": "pg_stat_activity_count{state=\"idle\"}",
            "legendFormat": "Idle"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Transactions per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m])",
            "legendFormat": "TPS"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Replication Lag",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_wal_lsn_diff(pg_stat_replication_pg_current_wal_lsn, pg_stat_replication_pg_last_xact_replay_timestamp)",
            "legendFormat": "{{client_addr}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))",
            "legendFormat": "Cache Hit Ratio"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.9, "color": "yellow"},
                {"value": 0.99, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Slow Queries",
        "type": "table",
        "targets": [
          {
            "expr": "pg_stat_statements_total_time / pg_stat_statements_calls > 1000",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 6,
        "title": "Storage Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "pg_database_size / 1024 / 1024 / 1024",
            "legendFormat": "{{datname}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
